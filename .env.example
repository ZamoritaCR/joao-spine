# COUNCIL_SSH_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----
# Option B: file path
# COUNCIL_SSH_PRIVATE_KEY_PATH=/app/.ssh/id_ed25519

# HMAC auth for /joao/dispatch
JOAO_DISPATCH_HMAC_SECRET=generate-a-strong-random-secret

# Telegram
